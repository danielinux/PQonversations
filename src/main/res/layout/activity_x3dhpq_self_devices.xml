<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- §10.6.1/§10.6.4 pending-enrollment banner: shown only while this device has
         no AIK yet and is waiting for confirmation by an existing device. -->
    <LinearLayout
        android:id="@+id/pending_enrollment_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/x3dhpq_pending_enrollment_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/x3dhpq_pending_enrollment_text"
            android:paddingBottom="8dp" />

        <!-- §10.6.4a: the default, non-destructive choice — pair with (associate under)
             the account's existing identity. Opens the new-device-side pairing screen. -->
        <Button
            android:id="@+id/associate_existing_identity_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/x3dhpq_associate_existing_identity_button" />

        <!-- §10.6.4b: the destructive alternative — mint a brand-new identity instead. -->
        <Button
            android:id="@+id/generate_new_identity_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/x3dhpq_generate_new_identity_button" />

    </LinearLayout>

    <!-- §10.6.5 identity-reconstruction re-trust list. -->
    <LinearLayout
        android:id="@+id/blocked_identities_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/x3dhpq_blocked_identities_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/x3dhpq_blocked_identities_help"
            android:paddingBottom="4dp" />

        <ListView
            android:id="@+id/blocked_identities_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Account AIK fingerprint: shown prominently so it can be compared out-of-band
         with a contact reading the same value on their device. -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/x3dhpq_aik_fp_label"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/aik_fingerprint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textIsSelectable="true"
        android:fontFamily="monospace"
        android:textSize="16sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/local_device_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp" />

    <ListView
        android:id="@+id/device_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- §10.6.2 both pairing directions: "Link a new device" shows this device's own
         code/QR for a new device to scan; "Confirm a waiting device" scans/consumes the
         code/QR already being shown by a pending device. Both drive PairNewDeviceActivity. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/add_device_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/x3dhpq_add_device" />

        <Button
            android:id="@+id/confirm_waiting_device_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/x3dhpq_confirm_waiting_device_button" />

    </LinearLayout>

</LinearLayout>
