<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/x3dhpq_pair_show_code_help"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/pairing_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:fontFamily="monospace"
        android:textIsSelectable="true"
        android:paddingBottom="16dp" />

    <ImageView
        android:id="@+id/pairing_qr"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:contentDescription="@string/x3dhpq_pair_new_device_title"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/pairing_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/x3dhpq_pair_status_waiting"
        android:paddingBottom="16dp" />

    <Button
        android:id="@+id/pair_cancel_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cancel" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- §10.6.2 "new-device-presents" direction: scan the QR shown by a pending
         device instead of waiting for it to scan/consume ours. -->
    <Button
        android:id="@+id/confirm_pending_device_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/x3dhpq_pair_confirm_pending_device_button" />

</LinearLayout>
